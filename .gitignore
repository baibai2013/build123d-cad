# build123d 导出文件（运行时生成，不纳入版本控制）
*.step
*.stp
*.stl
*.brep
*.3mf
*.gltf
*.glb
*.dxf

# 批量导出输出目录
exports/

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# 虚拟环境
.venv/
venv/
env/

# IDE
.DS_Store
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# Claude Code 本地配置（含个人 token/权限，不入版本控制）
.claude/settings.local.json

# 测试/临时文件
*.tmp
*.log

# verify_urdf.py 的 headless 验证截图(临时产物)
_verify/

# Cache
.mypy_cache/
__pycache__/

# 方案 F AIGC 生成的概念图（URL 可能过期 + 仓库膨胀，不入 git）
assets/concept/*
!assets/concept/.gitkeep

# 仿真/预览等运行时任务工作区(handoff output/<task>/)
output/

# vite 构建中间产物(只提交各引擎的 dist/,不提交 viewer-src/dist/)
skills/viewer/scripts/engines/*/viewer-src/dist/
